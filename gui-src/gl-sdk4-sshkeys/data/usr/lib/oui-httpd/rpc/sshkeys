--[[
    @object-name: sshkeys
    @object-desc: Manage dropbear authorized_keys (root) from the panel
--]]

local uci = require "uci"

local M = {}

local RENDER = "/usr/bin/gl_sshkeys"

-- Key types dropbear can actually verify. sk-* are FIDO/U2F security keys
-- (YubiKey); dropbear >= 2022.82 accepts them in authorized_keys.
local ALLOWED_TYPES = {
    ["ssh-ed25519"] = true,
    ["ssh-rsa"] = true,
    ["ecdsa-sha2-nistp256"] = true,
    ["ecdsa-sha2-nistp384"] = true,
    ["ecdsa-sha2-nistp521"] = true,
    ["sk-ssh-ed25519@openssh.com"] = true,
    ["sk-ecdsa-sha2-nistp256@openssh.com"] = true,
}

local function trim(s)
    return (tostring(s or ""):gsub("^%s+", ""):gsub("%s+$", ""))
end

-- uci option values and authorized_keys lines must stay single-line and free of
-- control characters: collapse whitespace runs, drop anything not printable
-- ASCII. ([%w%p ] rather than %g: the runtime is Lua 5.1, which lacks %g.)
local function clean_text(s)
    s = trim(s):gsub("%s+", " ")
    return (s:gsub("[^%w%p ]", ""))
end

-- uci auto-names anonymous sections positionally (cfgNNNNNN derived from index),
-- so deleting one RENAMES its successors: the id the panel holds for key B can,
-- after A is removed, point at key C. remove/set_enabled key off that id, so a
-- stale list would toggle or delete the wrong key. Give each section a STABLE
-- name derived from its blob (djb2, 8 hex) instead, so ids never move. Collisions
-- between distinct blobs are resolved by a suffix; identical blobs are caught as
-- duplicates before we get here.
local function section_name(blob)
    local h = 5381
    for i = 1, #blob do
        h = (h * 33 + blob:byte(i)) % 4294967296
    end
    -- format as two 16-bit halves: LuaJIT's %x refuses values >= 2^31
    -- ("integer expected, got number"), which a 32-bit hash hits half the time
    return string.format("k%04x%04x", math.floor(h / 65536), h % 65536)
end

-- Parse one authorized_keys line into {type, blob, comment}. Rejects anything
-- whose type we cannot verify or whose key data is not base64. Options prefixes
-- (e.g. `no-touch-required`) are NOT accepted here: v1 stores bare keys only.
local function parse_pubkey(line)
    line = trim(line)
    if line == "" then return nil, "empty" end
    local ktype, blob, comment = line:match("^(%S+)%s+(%S+)%s*(.*)$")
    if not ktype or not blob then return nil, "malformed" end
    if not ALLOWED_TYPES[ktype] then return nil, "unsupported key type" end
    if not blob:match("^[A-Za-z0-9+/]+=*$") or #blob < 40 then
        return nil, "invalid key data"
    end
    return { ktype = ktype, blob = blob, comment = clean_text(comment) }
end

local function render()
    local p = ngx.pipe.spawn({ RENDER, "render" })
    if p then p:wait() end
end

-- List installed keys. Never returns the full blob back into the DOM; a 16-char
-- tail is enough to disambiguate keys in the UI.
function M.list()
    local c = uci.cursor()
    local keys = {}
    c:foreach("sshkeys", "key", function(s)
        local blob = s.blob or ""
        keys[#keys + 1] = {
            id = s[".name"],
            name = s.name or "",
            type = s.type or "",
            comment = s.comment or "",
            tail = (#blob > 16) and blob:sub(-16) or blob,
            enabled = s.enabled ~= "0",
        }
    end)
    return { keys = keys }
end

-- The textarea accepts several keys at once, one per line. Parse every line
-- first and reject the whole request on the first bad one, so a paste is
-- atomic: nothing is stored unless everything parses.
function M.add(params)
    params = params or {}

    local list = {}
    for line in tostring(params.key or ""):gmatch("[^\r\n]+") do
        if trim(line) ~= "" then
            local parsed, err = parse_pubkey(line)
            if not parsed then return { error = err or "invalid key" } end
            list[#list + 1] = parsed
        end
    end
    if #list == 0 then return { error = "empty" } end

    local c = uci.cursor()
    local have = {}
    c:foreach("sshkeys", "key", function(s)
        if s.blob then have[s.blob] = true end
    end)

    local name = clean_text(params.name)
    local added, skipped = 0, 0
    for _, parsed in ipairs(list) do
        if have[parsed.blob] then
            skipped = skipped + 1
        else
            have[parsed.blob] = true
            -- The typed-in name labels a single key; on a multi-key paste each
            -- key falls back to its own comment (or type).
            local kname = name
            if kname == "" or #list > 1 then
                kname = parsed.comment ~= "" and parsed.comment or parsed.ktype
            end
            -- stable, blob-derived section name; suffix on the rare hash clash
            local sid = section_name(parsed.blob)
            if c:get("sshkeys", sid) then
                local n = 1
                while c:get("sshkeys", sid .. "_" .. n) do n = n + 1 end
                sid = sid .. "_" .. n
            end
            c:set("sshkeys", sid, "key")
            c:set("sshkeys", sid, "name", kname)
            c:set("sshkeys", sid, "type", parsed.ktype)
            c:set("sshkeys", sid, "blob", parsed.blob)
            if parsed.comment ~= "" then
                c:set("sshkeys", sid, "comment", parsed.comment)
            end
            c:set("sshkeys", sid, "enabled", "1")
            added = added + 1
        end
    end
    if added == 0 then return { error = "duplicate key" } end
    c:commit("sshkeys")

    render()
    return { ok = true, added = added, skipped = skipped }
end

function M.remove(params)
    params = params or {}
    local id = params.id
    if not id then return { error = "missing id" } end

    local c = uci.cursor()
    if c:get("sshkeys", id) ~= "key" then return { error = "not found" } end
    c:delete("sshkeys", id)
    c:commit("sshkeys")

    render()
    return { ok = true }
end

function M.set_enabled(params)
    params = params or {}
    local id = params.id
    if not id then return { error = "missing id" } end

    local c = uci.cursor()
    if c:get("sshkeys", id) ~= "key" then return { error = "not found" } end
    c:set("sshkeys", id, "enabled", params.enabled and "1" or "0")
    c:commit("sshkeys")

    render()
    return { ok = true }
end

return M
